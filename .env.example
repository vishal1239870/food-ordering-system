# Database Settings
MONGODB_URL=mongodb+srv://your_user:your_password@cluster0.example.mongodb.net/
MONGODB_DB_NAME=foodhub

# Security Settings
SECRET_KEY=generate-a-secure-secret-key-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App Settings
APP_NAME="FoodHub API"
DEBUG=True

# Default Admin (Internal use)
ADMIN_EMAIL=admin@foodhub.com
ADMIN_PASSWORD=admin123

# Google OAuth Settings
# Get these from Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
